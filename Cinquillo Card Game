void poner_carta_mantel(tmatriz *m, tmatriz maux, tcarta carta)
{
	int col, fil;
	switch (carta.pal)
	{
	case 'O':
		col = 0;
		break;
	case 'C':
		col = 1;
		break;
	case 'E':
		col = 2;
		break;
	default:
		col = 3;
		break;
	}
	for (fil = 0; fil < FIL; fil++)
	{
		if (carta.num1 == maux.matriz[fil][col].num1 && carta.num2 == maux.matriz[fil][col].num2 && m->matriz[fil][col].num2 == '-')
		{
			(*m).matriz[fil][col].pal = carta.pal;
			(*m).matriz[fil][col].num1 = carta.num1;
			(*m).matriz[fil][col].num2 = carta.num2;
		}
	}
}

void sacar_carta_jugador(tcarta carta, tjugador *jug)
{
	int k;

	for (k = 0; k < (*jug).ncartas; k++)
	{

		if ((*jug).vcartas[k].pal == carta.pal && (*jug).vcartas[k].num1 == carta.num1 && (*jug).vcartas[k].num2 == carta.num2)
		{
			(*jug).vcartas[k].pal = (*jug).vcartas[(*jug).ncartas - 1].pal;
			(*jug).vcartas[k].num1 = (*jug).vcartas[(*jug).ncartas - 1].num1;
			(*jug).vcartas[k].num2 = (*jug).vcartas[(*jug).ncartas - 1].num2;
			(*jug).ncartas--;
			return; // es necesario???
		}
	}
}

void buscar_posibles_jugador(tmatriz m, tmatriz maux, tjugador jug, tcarta *p, int *num_posibles_jugadas)
{
	int i;
	tjugador posibles_tiradas;

	buscar_posibles(m, maux, &posibles_tiradas);

	*num_posibles_jugadas = 0;

	if (posibles_tiradas.ncartas == 0)
	{
		printf("Ninguna! :-/ Paso.");
	}

	else
	{
		for (i = 0; i < posibles_tiradas.ncartas; i++)
		{
			if (jugador_tiene_carta(jug, posibles_tiradas.vcartas[i]))
			{
				p[*num_posibles_jugadas] = posibles_tiradas.vcartas[i];
				*num_posibles_jugadas = *num_posibles_jugadas + 1;
			}
		}
	}
}

int jugador_cinco_oros(tjugadores *pj)
{
	int i, j;
	tcarta carta;

	for (i = 0; i < 4; i++)
	{
		for (j = 0; j < pj->jugadores[i].ncartas; j++)
		{
			carta = pj->jugadores[i].vcartas[j];
			if (carta.pal == 'O' && carta.num1 == ' ' && carta.num2 == '5')
			{
				pj->jugadores[i].vcartas[j] = pj->jugadores[i].vcartas[pj->jugadores[i].ncartas - 1];
				pj->jugadores[i].ncartas--;
				return i;
			}
		}
	}
	return -1;
}
