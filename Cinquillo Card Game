void buscar_posibles(tmatriz m, tmatriz maux, tjugador *p)
{
	int i, j; // contadores

	p->ncartas = 0;
	for (i = 0; i < COL; i++)
	{
		if (m.matriz[5][i].num2 != '5')
		{ // se usa para las cartas con el 5 que no se han tirdo aun
			p->vcartas[p->ncartas] = maux.matriz[5][i];
			p->ncartas++;
		}
		else
		{
			for (j = 4; j >= 0; j--)
			{ // revisa por abajo hasta encontrar un numero que esté disponible
				if (m.matriz[j][i].num2 == '-')
				{
					p->vcartas[p->ncartas] = maux.matriz[j][i];
					p->ncartas++;
					j = -1; // sale del bucle, es decir, solo hay una iteracion del for, (break)
				}
			}
			for (j = 6; j < FIL; j++)
			{
				if (m.matriz[j][i].num2 == '-')
				{
					p->vcartas[p->ncartas] = maux.matriz[j][i];
					p->ncartas++;
					j = FIL; // sale del bucle, es decir, solo hay una iteracion del for, (break)
				}
			}
		}
	}
}

int jugador_tiene_carta(tjugador j, tcarta c)
{
	int i;

	for (i = 0; i < j.ncartas; i++)
	{
		if ((j.vcartas[i].pal == c.pal) && (j.vcartas[i].num1 == c.num1) && (j.vcartas[i].num2 == c.num2))
		{
			return 1;
		}
	}

	return 0;
}

void asignar_baraja(tbaraja *bj)
{
	int i;

	for (i = 0; i < 40; i++)
	{
		// Asignar palo
		if (i < 10)
			bj->vcartas[i].pal = 'O';
		else if (i < 20)
			bj->vcartas[i].pal = 'C';
		else if (i < 30)
			bj->vcartas[i].pal = 'E';
		else
			bj->vcartas[i].pal = 'B';

		// Asignar num1
		if ((i % 10) >= 7)
			bj->vcartas[i].num1 = '1';
		else
			bj->vcartas[i].num1 = ' ';

		// Asignar num2
		if ((i) % 10 >= 7)
		{
			if (i % 10 == 7)
				bj->vcartas[i].num2 = '0';
			else if (i % 10 == 8)
				bj->vcartas[i].num2 = '1';
			else
				bj->vcartas[i].num2 = '2';
		}
		else
			bj->vcartas[i].num2 = 48 + 1 + i % 10;
	}
}

void mezclar_baraja(tbaraja *bj)
{
	int azar1, azar2,
		int i;
	tcarta aux;

	for (i = 0; i < 40; i++)
	{
		azar1 = numero_al_azar(40);
		azar2 = numero_al_azar(40);
		aux = bj->vcartas[azar1];
		bj->vcartas[azar1] = bj->vcartas[azar2];
		bj->vcartas[azar2] = aux;
	}
}

