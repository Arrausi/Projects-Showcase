void inicializar_mantel(tmatriz *pm)
{
	int col, fil;

	for (col = 0; col < COL; col++)
	{
		for (fil = 0; fil < FIL; fil++)
		{
			(pm->matriz[fil][col].pal) = '-';
			(pm->matriz[fil][col].num1) = ' ';
			(pm->matriz[fil][col].num2) = '-';
		}
	}
	(pm->matriz[5][0].pal) = 'O';
	(pm->matriz[5][0].num1) = ' ';
	(pm->matriz[5][0].num2) = '5';
}

void imprimir_mantel(tmatriz pm)
{
	int fil, col;

	printf_color_num(3);
